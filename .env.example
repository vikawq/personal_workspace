# Optional npm registry mirror for Docker builds.
# Example for China mirror:
# NPM_REGISTRY=https://registry.npmmirror.com
NPM_REGISTRY=

# Optional corporate proxy for Docker builds.
# Example:
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,backend,frontend
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,backend,frontend

# Required backend encryption key. Use at least 32 characters.
# Generate one in WSL:
# openssl rand -base64 32
ENCRYPTION_KEY=
ENCRYPTION_SALT=personal-workbench:v1
