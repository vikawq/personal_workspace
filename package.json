{
  "name": "personal-workbench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:frontend": "vite --host 0.0.0.0",
    "dev:backend": "npm run backend:build && node --env-file=.env --watch backend/dist/server.js",
    "build": "npm run build:frontend && npm run backend:build",
    "build:frontend": "tsc --noEmit && vite build",
    "backend:build": "tsc -p backend/tsconfig.json",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit && tsc -p backend/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.1",
    "markdown-it": "^14.2.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  }
}
